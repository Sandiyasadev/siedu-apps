        {
            "parameters": {
                "jsCode": "const raw = $input.first().json.text || $input.first().json.response?.text || '';\nconst match = raw.match(/\\{[\\s\\S]*\\}/);\n\nlet parsed;\ntry {\n  parsed = JSON.parse(match ? match[0] : raw);\n} catch {\n  parsed = {\n    intent: 'faq',\n    rag_search_query: $('Format History').first().json.user_message,\n    kb_type: 'faq',\n    reply_direct: ''\n  };\n}\n\nconst validTypes = ['faq', 'policy', 'product_info', 'troubleshooting', 'internal_guideline'];\nif (!validTypes.includes(parsed.kb_type)) {\n  parsed.kb_type = 'faq';\n}\n\nreturn [{\n  json: {\n    ...parsed,\n    history: $('Format History').first().json.history,\n    user_message: $('Format History').first().json.user_message,\n    conversation_id: $('Format History').first().json.conversation_id,\n    bot_id: $('Format History').first().json.bot_id,\n    user_id: $('Format History').first().json.user_id,\n    user_name: $('Format History').first().json.user_name\n  }\n}];"
            },
