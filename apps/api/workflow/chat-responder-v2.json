{
    "name": "V2 Chat Responder — Multi-Channel",
    "nodes": [
        {
            "parameters": {
                "httpMethod": "POST",
                "path": "chat-message",
                "responseMode": "responseNode",
                "options": {}
            },
            "id": "55123a84-d3f5-4cb4-8330-bb7bc982e700",
            "name": "Chat Webhook",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 2,
            "position": [
                -400,
                300
            ],
            "webhookId": "chat-message"
        },
        {
            "parameters": {
                "jsCode": "return items.map(item => {\n  const payload = item.json;\n  if (!payload.body) {\n    return { json: { error: 'Invalid payload structure' } };\n  }\n\n  const body = payload.body;\n  const channel = body.channel_type;\n\n  let normalized = {\n    botId: body.bot_id || null,\n    channel: channel || null,\n    conversationId: body.conversation_id || null,\n    threadId: body.external_thread_id || null,\n    user: {\n      id: null,\n      name: null,\n      username: null\n    },\n    message: {\n      id: null,\n      text: null,\n      type: body.message_type || null,\n      timestamp: null\n    },\n    raw: body.raw || null\n  };\n\n  if (channel === 'telegram') {\n    normalized.user.id = body.user?.external_id || body.raw?.message?.from?.id || null;\n    normalized.user.name = body.user?.name || `${body.raw?.message?.from?.first_name || ''} ${body.raw?.message?.from?.last_name || ''}`.trim();\n    normalized.user.username = body.user?.username || body.raw?.message?.from?.username || null;\n    normalized.message.id = body.raw?.message?.message_id || null;\n    normalized.message.text = body.raw?.message?.text || body.text || null;\n    normalized.message.timestamp = body.raw?.message?.date || null;\n  }\n\n  if (channel === 'whatsapp') {\n    normalized.user.id = body.user?.external_id || body.user?.wa_id || body.raw?.message?.from || null;\n    normalized.user.name = body.user?.name || body.user?.profile?.name || body.raw?.contact?.profile?.name || null;\n    normalized.user.username = null;\n    normalized.message.id = body.wa_message_id || body.raw?.message?.id || null;\n    normalized.message.text = body.raw?.message?.text?.body || body.text || null;\n    normalized.message.timestamp = body.raw?.message?.timestamp || null;\n  }\n\n  return { json: normalized };\n});"
            },
