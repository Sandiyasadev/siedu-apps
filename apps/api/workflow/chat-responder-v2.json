        {
            "parameters": {
                "jsCode": "return items.map((item) => {\n    let content = String(item.json.output || item.json.response || item.json.reply_direct || '');\n\n    // 1) Remove thinking/analysis blocks\n    content = content\n      .replace(/<thinking[\\s\\S]*?<\\/thinking>/gi, '')\n      .replace(/<analysis[\\s\\S]*?<\\/analysis>/gi, '')\n      .replace(/<reasoning[\\s\\S]*?<\\/reasoning>/gi, '');\n\n    // 2) Remove remaining HTML/XML tags\n    content = content.replace(/<\\/?[^>]+>/g, '');\n\n    // 3) Clean excess whitespace\n    content = content.replace(/\\n{3,}/g, '\\n\\n').trim();\n\n    // 4) Fallback if empty\n    if (!content) {\n      content = 'Maaf Kak, saya sedang mengalami kendala teknis. Mohon coba lagi ya 🙏';\n    }\n\n    item.json.content = content;\n    return item;\n});"
            },
