            },
            "id": "llm-micro",
            "name": "Nova Micro (Classifier)",
            "type": "@n8n/n8n-nodes-langchain.lmChatAwsBedrock",
            "typeVersion": 1.1,
            "position": [
                -140,
                520
            ],
            "credentials": {
                "aws": {
                    "id": "w1WID0kdD8RQoTjj",
                    "name": "us-api"
                }
            }
        },
        {
            "parameters": {
                "jsCode": "const raw = $input.first().json.text || $input.first().json.response?.text || '';\nconst match = raw.match(/\\{[\\s\\S]*\\}/);\n\nlet parsed;\ntry {\n  parsed = JSON.parse(match ? match[0] : raw);\n} catch {\n  parsed = {\n    intent: 'faq',\n    rag_search_query: $('Format History').first().json.user_message,\n    kb_type: 'faq',\n    reply_direct: ''\n  };\n}\n\n// Validate kb_type\nconst validTypes = ['faq', 'policy', 'product_info', 'troubleshooting', 'internal_guideline'];\nif (!validTypes.includes(parsed.kb_type)) {\n  parsed.kb_type = 'faq';\n}\n\nreturn [{\n  json: {\n    ...parsed,\n    history: $('Format History').first().json.history,\n    user_message: $('Format History').first().json.user_message,\n    chat_id: $('Format History').first().json.chat_id,\n    user_id: $('Format History').first().json.user_id,\n    user_name: $('Format History').first().json.user_name\n  }\n}];"
            },
            "id": "parse-classifier",
            "name": "Parse Classifier",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                80,
                300
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "options": {
                        "caseSensitive": true,
                        "typeValidation": "strict",
                        "version": 3
                    },
                    "conditions": [
                        {
                            "id": "check-greeting",
                            "leftValue": "={{ $json.intent }}",
                            "rightValue": "greeting",
                            "operator": {
                                "type": "string",
                                "operation": "equals"
                            }
                        }
                    ],
                    "combinator": "and"
                },
                "options": {}
            },
