      "typeVersion": 4.2,
      "position": [
        -1000,
        -800
      ],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const ctx = $('Prepare Context').first().json;\nconst intentData = $('Merge Intent').first().json;\nconst hist = $('Fetch History').first().json;\nconst tplPayload = $input.first()?.json || {};\nlet templates = [];\nif (Array.isArray(tplPayload.templates)) templates = tplPayload.templates;\nelse if (Array.isArray(tplPayload.data?.templates)) templates = tplPayload.data.templates;\nelse if (Array.isArray(tplPayload.items)) templates = tplPayload.items;\nlet templates_xml = 'Tidak ada template khusus. Gunakan gaya bahasa natural.';\nif (templates.length > 0) {\n  templates_xml = templates.map(t =>\n    '<TEMPLATE name=\"' + (t.name||'') + '\" intent=\"' + (t.sub_category||t.category||'general') + '\">\\n' + (t.content || '') + '\\n</TEMPLATE>'\n  ).join('\\n\\n');\n}\nreturn [{\n  json: {\n    ...ctx,\n    intent: intentData.intent,\n    wasForced: intentData.wasForced,\n    useGreetingLlm: !!intentData.useGreetingLlm,\n    template_sub_category: intentData.templateSubCategory || intentData.intent,\n    history: hist.history_text || '',\n    time_context: hist.time_context || '',\n    greeting_word: hist.greeting_word || '',\n    prompt_instruction: hist.contact_status?.promptInstruction || '',\n    templates_xml,\n    templates_count: templates.length,\n    template_fetch_error: tplPayload.error || tplPayload.message || null,\n    rag_search_query: ctx.user_message,\n    kb_type: 'faq'\n  }\n}];"
      },
