    {
      "parameters": {
        "jsCode": "const forced = $('Fetch History').first().json.contact_status?.forcedIntent || null;\nlet classified = forced;\nif (!forced) {\n  try { classified = ($('Intent Classifier').first().json.text || '').trim().toLowerCase(); } catch(e) { classified = ''; }\n}\nconst valid = [\"engagement.greeting_new\",\"engagement.greeting_return\",\"engagement.time_inquiry\",\"discovery.program_detail\",\"discovery.schedule_location\",\"discovery.tutor_profile\",\"discovery.curriculum\",\"evaluation.pricing_inquiry\",\"evaluation.objection_price\",\"evaluation.objection_compare\",\"evaluation.objection_risk\",\"evaluation.objection_authority\",\"evaluation.objection_urgency\",\"conversion.soft\",\"conversion.transaction\",\"conversion.confirm\",\"retention.complaint_service\",\"retention.complaint_refund\",\"retention.progress_inquiry\",\"retention.reschedule\"];\nconst intent = valid.includes(classified) ? classified : 'discovery.program_detail';\nconst wasForced = !!forced;\nconst templateSubCategory = intent;\nconst useGreetingLlm = wasForced && /^engagement\\.greeting_/.test(intent);\nreturn [{ json: { intent, wasForced, templateSubCategory, useGreetingLlm } }];"
      },
      "id": "merge-intent",
      "name": "Merge Intent",
