    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const body = item.json?.body || {};\n  const ch = body.channel_type;\n  let n = {\n    botId: body.bot_id || null, channel: ch || null,\n    conversationId: body.conversation_id || null,\n    threadId: body.external_thread_id || null,\n    user: { id: null, name: null, username: null },\n    message: { id: null, text: null, type: body.message_type || null, timestamp: null },\n    raw: body.raw || null\n  };\n  if (ch === 'telegram') {\n    n.user.id = body.user?.external_id || body.raw?.message?.from?.id || null;\n    n.user.name = body.user?.name || [body.raw?.message?.from?.first_name, body.raw?.message?.from?.last_name].filter(Boolean).join(' ') || null;\n    n.user.username = body.user?.username || body.raw?.message?.from?.username || null;\n    n.message.id = body.raw?.message?.message_id || null;\n    n.message.text = body.raw?.message?.text || body.text || null;\n    n.message.timestamp = body.raw?.message?.date || null;\n  }\n  if (ch === 'whatsapp') {\n    n.user.id = body.user?.external_id || body.user?.wa_id || body.raw?.message?.from || null;\n    n.user.name = body.user?.name || body.user?.profile?.name || body.raw?.contact?.profile?.name || null;\n    n.message.id = body.wa_message_id || body.raw?.message?.id || null;\n    n.message.text = body.raw?.message?.text?.body || body.text || null;\n    n.message.timestamp = body.raw?.message?.timestamp || null;\n  }\n  return { json: n };\n});"
      },
